<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane styleClass="figma-login-root"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.frontend_emp_pass_slip.controller.LoginController">

    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <Pane styleClass="login-bg-circle-top-left"
          StackPane.alignment="TOP_LEFT" />

    <Pane styleClass="login-bg-circle-bottom-right"
          StackPane.alignment="BOTTOM_RIGHT" />

    <VBox alignment="CENTER" spacing="20" maxWidth="450">

        <VBox alignment="CENTER" spacing="8">
            <StackPane styleClass="pup-logo-circle">
                <ImageView fitWidth="78" fitHeight="78" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../images/pup-logo.png" />
                    </image>
                </ImageView>
            </StackPane>

            <Label text="Pass Slip System" styleClass="figma-login-title" />
            <Label text="Employee Issuance &amp; Monitoring" styleClass="figma-login-subtitle" />
        </VBox>

        <VBox fx:id="loginCard" styleClass="figma-login-card" spacing="16" maxWidth="410">
            <padding>
                <Insets top="28" right="32" bottom="28" left="32" />
            </padding>

            <VBox spacing="3">
                <Label fx:id="welcomePortalLabel" text="Welcome Portal" styleClass="figma-card-title" />
                <Label fx:id="roleSubtitleLabel" text="Sign in to your administrator account" styleClass="figma-card-subtitle" />
            </VBox>

            <VBox spacing="6">
                <Label fx:id="selectPortalLabel" text="Select Portal *" styleClass="figma-field-label" />
                <HBox spacing="8" alignment="CENTER" maxWidth="Infinity">
                    <fx:define>
                        <ToggleGroup fx:id="roleToggleGroup" />
                    </fx:define>
                    <ToggleButton text="Administrators"
                                  toggleGroup="$roleToggleGroup"
                                  selected="true"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="36"
                                  styleClass="role-toggle-button"
                                  onAction="#handleRoleChange" />
                    <ToggleButton text="Guards"
                                  toggleGroup="$roleToggleGroup"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="36"
                                  styleClass="role-toggle-button"
                                  onAction="#handleRoleChange" />
                    <ToggleButton text="Directors"
                                  toggleGroup="$roleToggleGroup"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="36"
                                  styleClass="role-toggle-button"
                                  onAction="#handleRoleChange" />
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label fx:id="usernameLabel" text="Username *" styleClass="figma-field-label" />
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           onAction="#login"
                           prefHeight="38" />
            </VBox>

            <VBox spacing="6">
                <Label fx:id="passwordLabel" text="Password *" styleClass="figma-field-label" />
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               onAction="#login"
                               prefHeight="38" />
            </VBox>

            <Label fx:id="statusLabel"
                   wrapText="true"
                   styleClass="error-label" />

            <Button fx:id="loginButton"
                    text="Sign In"
                    maxWidth="Infinity"
                    prefHeight="42"
                    onAction="#login"
                    styleClass="figma-login-button" />

            <HBox alignment="CENTER" spacing="40">
                <Hyperlink text="Terms and Conditions" onAction="#handleTerms" styleClass="footer-card-link" />
                <Hyperlink text="Privacy and Policy" onAction="#handlePrivacy" styleClass="footer-card-link" />
            </HBox>
        </VBox>

        <Label text="© 2026 University Administration Portal" styleClass="figma-footer-text" />

    </VBox>
</StackPane>