<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-background-color: #ffffff; -fx-background-radius: 12;"
      stylesheets="@../css/style.css" prefWidth="500" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend_emp_pass_slip.controller.AdminPassSlipDetailModalController">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- Header Title -->
    <HBox alignment="CENTER_LEFT" style="-fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 12 0;">
        <VBox HBox.hgrow="ALWAYS">
            <Label fx:id="modalSlipNoLabel" text="Pass Slip Detail" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label fx:id="modalTimeRequestedLabel" text="Requested at: --:--" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
        </VBox>
        <Label fx:id="modalBadgeLabel" text="PENDING" style="-fx-padding: 4 10; -fx-background-radius: 20; -fx-font-size: 11px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Data Layout Grid -->
    <GridPane vgap="14" hgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="130" prefWidth="140" maxWidth="150" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Employee ID:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="modalEmpIdLabel" text="N/A" style="-fx-text-fill: #1e293b;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Full Name:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="modalNameLabel" text="N/A" style="-fx-text-fill: #1e293b; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Department:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="modalDeptLabel" text="N/A" style="-fx-text-fill: #1e293b;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Destination:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="modalDestinationLabel" text="N/A" style="-fx-text-fill: #1e293b;" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Reason / Nature:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="modalReasonLabel" text="N/A" style="-fx-text-fill: #1e293b;" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Estimated Windows:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <VBox spacing="2" GridPane.rowIndex="5" GridPane.columnIndex="1">
            <Label fx:id="modalEstOutLabel" text="Est. Out: --:--" style="-fx-text-fill: #e11d48; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label fx:id="modalEstInLabel" text="Est. In: --:--" style="-fx-text-fill: #0d9488; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </VBox>
    </GridPane>

    <!-- Contextual Control Container: ONLY CANCEL FOR ADMIN -->
    <HBox fx:id="actionButtonContainer" spacing="10" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
        <Button text="Approve" onAction="#handleApprove" style="-fx-background-color: #16a34a; -fx-text-fill: white;" />
        <Button text="Reject" onAction="#handleReject" style="-fx-background-color: #dc2626; -fx-text-fill: white;" />
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #64748b; -fx-text-fill: white;" />
    </HBox>
</VBox>